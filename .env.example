# =============================================================
# APEX v2 - Environment Variables
# Copy this file to .env and fill in production values.
# =============================================================

# ---- PostgreSQL ----
POSTGRES_DB=apex_v2
POSTGRES_USER=apex
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ---- Application database URL (constructed from above in docker-compose) ----
DATABASE_URL=postgresql+asyncpg://apex:CHANGE_ME_TO_A_STRONG_PASSWORD@apex-db:5432/apex_v2

# ---- Redis ----
REDIS_URL=redis://apex-redis:6379/0

# ---- Celery ----
CELERY_BROKER_URL=redis://apex-redis:6379/1
CELERY_RESULT_BACKEND=redis://apex-redis:6379/2

# ---- Security ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET

# ---- Anthropic / Claude ----
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=https://your-domain.com

# ---- Misc ----
DEBUG=false
